    "eslint-plugin-simple-import-sort": "^12.1.0",
    "jiti": "^2.6.1",
    "prettier": "^3.2.5",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.0.0"
  },
  "dependencies": {
    "@fastify/static": "^6.12.0",
    "@types/nodemailer": "^7.0.11",
    "nodemailer": "^8.0.4"
